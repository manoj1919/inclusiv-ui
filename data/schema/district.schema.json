{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/manoj1919/inclusiv-ui/blob/main/data/schema/district.schema.json",
  "title": "District Profile",
  "description": "California school district profile organized under the Donabedian Structure-Process-Outcome quality model, operationalized with the IDEA Part B SPP/APR indicators. See docs/framework.md for the architectural decision and closure principle. Every measurable field carries provenance (source, as_of date, fetched_at, URL). AI-generated fields are explicitly flagged.",
  "type": "object",
  "required": [
    "schema_version",
    "cds_code",
    "name",
    "county",
    "county_code",
    "district_type",
    "last_updated"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2.0",
      "description": "0.2.0 reorganizes measures under structure/process/outcome top-level objects per the framework decision (2026-05-30)."
    },
    "cds_code": {
      "type": "string",
      "pattern": "^\\d{2}-\\d{5}$"
    },
    "name": { "type": "string" },
    "county": { "type": "string" },
    "county_code": { "type": "string", "pattern": "^\\d{2}$" },
    "district_type": {
      "type": "string",
      "enum": [
        "Unified K-12",
        "Elementary K-8",
        "Elementary K-6",
        "High School Only",
        "Other"
      ]
    },
    "region": { "type": "string" },
    "website": { "type": "string", "format": "uri" },
    "selpa": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["single-district", "multi-district", "regional", "unknown"]
        },
        "url": { "type": "string", "format": "uri" }
      }
    },

    "enrollment": {
      "type": "object",
      "description": "Population description. Not a quality measure on its own — used to normalize Structure ratios (per-100-SWD, per-1000-students).",
      "additionalProperties": false,
      "properties": {
        "total": { "$ref": "#/$defs/SourcedInt" },
        "students_with_iep": { "$ref": "#/$defs/SourcedInt" },
        "students_with_autism": { "$ref": "#/$defs/SourcedInt" },
        "pct_iep": { "$ref": "#/$defs/SourcedNumber" },
        "pct_autism": { "$ref": "#/$defs/SourcedNumber" }
      }
    },

    "structure": {
      "type": "object",
      "description": "Donabedian Structure — what the district has in place. Staffing, programs, related services, independent reviews. SPP/APR indicators 11, 12 + supporting structure measures.",
      "additionalProperties": false,
      "properties": {
        "staffing": {
          "type": "object",
          "description": "Certificated staff counts and density ratios. Source: CDE Staff Race/Ethnicity (StRE) file at district level. CBEDS aggregates roles into broad types — granular SPED-specific role counts (special-ed teacher, SLP, OT, BCBA) are no longer published as a downloadable district-level file post 2018-19.",
          "additionalProperties": false,
          "properties": {
            "teachers": { "$ref": "#/$defs/SourcedInt" },
            "pupil_services": { "$ref": "#/$defs/SourcedInt", "description": "Counselors + psychologists + SLPs + nurses + social workers, aggregated. Cannot be split further from this source." },
            "administrators": { "$ref": "#/$defs/SourcedInt" },
            "other_certificated": { "$ref": "#/$defs/SourcedInt" },
            "all_certificated": { "$ref": "#/$defs/SourcedInt" },
            "teachers_per_100_iep": { "$ref": "#/$defs/SourcedNumber" },
            "pupil_services_per_1k_students": { "$ref": "#/$defs/SourcedNumber" },
            "pupil_services_per_100_iep": { "$ref": "#/$defs/SourcedNumber" }
          }
        },
        "programs": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "autism_specific_classrooms": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "grade_range": { "type": "string" },
                  "site": { "type": "string" }
                }
              }
            },
            "bcba_on_staff": { "$ref": "#/$defs/SourcedBool" },
            "aac_support_level": { "$ref": "#/$defs/SourcedEnum" },
            "transition_18_22_program": { "$ref": "#/$defs/SourcedBool" },
            "reverse_inclusion": { "$ref": "#/$defs/SourcedBool" }
          }
        },
        "related_services": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "slp_caseload_ratio": { "$ref": "#/$defs/SourcedNumber" },
            "ot_available": { "$ref": "#/$defs/SourcedBool" },
            "pt_available": { "$ref": "#/$defs/SourcedBool" },
            "social_skills_groups": { "$ref": "#/$defs/SourcedBool" }
          }
        },
        "reviews": {
          "type": "object",
          "description": "Independent reviews: existence and headline finding from FCMAT / CDE compliance monitoring.",
          "additionalProperties": false,
          "properties": {
            "state_audit_findings_5yr": { "$ref": "#/$defs/SourcedInt" }
          }
        },
        "district_web_research": {
          "type": "object",
          "description": "Provenance for the structure.programs and structure.related_services fields when sourced from hand-collected web research.",
          "required": ["researched_at", "additional_findings", "sources"],
          "additionalProperties": false,
          "properties": {
            "researched_at": { "type": "string", "format": "date" },
            "district_website": { "type": "string", "format": "uri" },
            "additional_findings": { "type": "string" },
            "sources": {
              "type": "array",
              "items": { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },

    "process": {
      "type": "object",
      "description": "Donabedian Process — what happens during service delivery. Placement decisions, dispute resolution activity, parent partnership. SPP/APR indicators 5, 6, 8, 13.",
      "additionalProperties": false,
      "properties": {
        "lre": {
          "type": "object",
          "description": "Least Restrictive Environment placement (SPP Indicator 5). All percentages on 0.0-1.0 scale.",
          "additionalProperties": false,
          "properties": {
            "lre_80pct_plus_gen_ed_all_disabilities": { "$ref": "#/$defs/SourcedNumber" },
            "lre_80pct_plus_gen_ed_autism": { "$ref": "#/$defs/SourcedNumber" },
            "lre_separate_setting_all_disabilities": { "$ref": "#/$defs/SourcedNumber" },
            "lre_separate_setting_autism": { "$ref": "#/$defs/SourcedNumber" }
          }
        },
        "disputes": {
          "type": "object",
          "description": "OAH due-process volume (5-year rolling) and OCR civil-rights snapshot. Process measures of how often disputes reach formal complaint stages.",
          "additionalProperties": false,
          "properties": {
            "oah_cases_5yr_total": { "$ref": "#/$defs/SourcedInt" },
            "oah_cases_5yr_autism": { "$ref": "#/$defs/SourcedInt" },
            "ocr_open_investigations": { "$ref": "#/$defs/SourcedInt" },
            "ocr_open_investigations_disability": { "$ref": "#/$defs/SourcedInt" }
          }
        }
      }
    },

    "outcome": {
      "type": "object",
      "description": "Donabedian Outcome — what results for students. Academic proficiency, behavior, post-school outcomes. SPP/APR indicators 1, 2, 3, 4, 7, 9, 10, 14.",
      "additionalProperties": false,
      "properties": {
        "academics": {
          "type": "object",
          "description": "California School Dashboard — Distance From Standard in raw points (negative = below standard). SPP Indicator 3.",
          "additionalProperties": false,
          "properties": {
            "ela_distance_from_standard_swd": { "$ref": "#/$defs/SourcedNumber" },
            "ela_distance_from_standard_all": { "$ref": "#/$defs/SourcedNumber" },
            "math_distance_from_standard_swd": { "$ref": "#/$defs/SourcedNumber" },
            "math_distance_from_standard_all": { "$ref": "#/$defs/SourcedNumber" }
          }
        },
        "behavior": {
          "type": "object",
          "description": "Attendance and discipline outcomes. SPP Indicator 4. Percentages on 0.0-1.0 scale.",
          "additionalProperties": false,
          "properties": {
            "chronic_absenteeism_rate_swd": { "$ref": "#/$defs/SourcedNumber" },
            "chronic_absenteeism_rate_all": { "$ref": "#/$defs/SourcedNumber" },
            "suspension_rate_swd": { "$ref": "#/$defs/SourcedNumber" },
            "suspension_rate_all": { "$ref": "#/$defs/SourcedNumber" }
          }
        }
      }
    },

    "housing_context": {
      "type": "object",
      "description": "External context (cost of living). Not a quality measure.",
      "additionalProperties": false,
      "properties": {
        "median_home_price_usd": { "$ref": "#/$defs/SourcedInt" },
        "median_rent_usd": { "$ref": "#/$defs/SourcedInt" }
      }
    },

    "ai_summaries": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overview": { "$ref": "#/$defs/AIGenerated" },
        "compliance_explained": { "$ref": "#/$defs/AIGenerated" },
        "programs_explained": { "$ref": "#/$defs/AIGenerated" },
        "what_this_means_for_parents": { "$ref": "#/$defs/AIGenerated" }
      }
    },

    "data_sources_used": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["cde_spedps", "cde_enrollment", "cde_staff", "ca_dashboard", "oah", "ocr", "district_web", "selpa_report", "zillow", "manual"]
      }
    },

    "build_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline_version", "built_at"],
      "properties": {
        "pipeline_version": { "type": "string" },
        "built_at": { "type": "string", "format": "date-time" },
        "raw_snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source", "path", "sha256"],
            "properties": {
              "source": { "type": "string" },
              "path": { "type": "string" },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        }
      }
    },

    "last_updated": { "type": "string", "format": "date" }
  },

  "$defs": {
    "SourcedInt": {
      "type": "object",
      "required": ["value", "source", "as_of"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["integer", "null"] },
        "source": { "type": "string" },
        "as_of": { "type": "string", "format": "date" },
        "fetched_at": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "SourcedNumber": {
      "type": "object",
      "required": ["value", "source", "as_of"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["number", "null"] },
        "source": { "type": "string" },
        "as_of": { "type": "string", "format": "date" },
        "fetched_at": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "SourcedBool": {
      "type": "object",
      "required": ["value", "source", "as_of"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["boolean", "null"] },
        "source": { "type": "string" },
        "as_of": { "type": "string", "format": "date" },
        "fetched_at": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "SourcedEnum": {
      "type": "object",
      "required": ["value", "source", "as_of"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["string", "null"] },
        "source": { "type": "string" },
        "as_of": { "type": "string", "format": "date" },
        "fetched_at": { "type": "string", "format": "date-time" },
        "url": { "type": "string", "format": "uri" },
        "note": { "type": "string" }
      }
    },
    "AIGenerated": {
      "type": "object",
      "required": ["value", "ai_generated", "ai_model", "ai_generated_at", "ai_disclaimer"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "ai_generated": { "const": true },
        "ai_model": { "type": "string" },
        "ai_generated_at": { "type": "string", "format": "date-time" },
        "ai_disclaimer": { "type": "string" },
        "based_on_sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
